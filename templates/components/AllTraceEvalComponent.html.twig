<div{{ attributes }}>
    <div class="alert alert-info">
        Si une trace est marquée d'un badge check, cela signifie que toutes ses compétences ont été évaluées.
    </div>
    <div class="col-12">
        <p class="text-muted">
            Filtres
        </p>
    </div>
    <div class="row">
        <div class="filtre-btn col-12">
            <button class="btn btn-primary"
                    data-action="live#action"
                    data-live-action-param="changeSemestre"
                    data-live-id-param="0"
                    {{ this.selectedSemestreId == null ? 'disabled' : '' }}
            >Tous les semestres</button>

            {% for semestre in semestres %}
                <button class="btn btn-primary"
                        data-action="live#action"
                        data-live-action-param="changeSemestre"
                        data-live-id-param="{{ semestre.id }}"
                        {{ this.selectedSemestreId == semestre.id ? 'disabled' : '' }}
                >{{ semestre.libelle }}</button>
            {% endfor %}
        </div>
    </div>

    <div class="row">
        {# Filtre compétences #}
        <div class="accordion accordion-flush col-4 g-4 filter-drop" id="accordionCompetences">
            <div class="accordion-item">
                <h2 class="accordion-header" id="flush-headingOne">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse"
                            data-bs-target="#flush-collapseOne" aria-expanded="false"
                            aria-controls="flush-collapseOne">
                        Filtrer par compétences
                    </button>
                </h2>
                <div id="flush-collapseOne" class="accordion-collapse collapse"
                     aria-labelledby="flush-headingOne"
                     data-bs-parent="#accordionCompetences">
                    <div class="accordion-body row">
                        <div>
                            <fieldset style="max-height: 200px; overflow-y: scroll;">
                                {% for cpt in niveaux %}
                                    <div style="display: flex" class="form-check">
                                        <input type="checkbox" id="{{ cpt.id }}"
                                               name="{{ cpt.id }}"
                                               data-model="selectedCompetences[]"
                                               data-action="live#action"
                                               data-live-action-param="changeCompetences"
                                               value="{{ cpt.id }}"
                                               class="form-check-input">
                                        <label for="{{ cpt.id }}" style="margin-left: 10px"
                                               class="form-check-label">{{ cpt.libelle }}</label><br>
                                    </div>
                                    <hr>
                                {% endfor %}
                            </fieldset>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        {# Filtre groupes #}
        <div class="accordion accordion-flush col-4 g-4 filter-drop" id="accordionGroupes">
            <div class="accordion-item">
                <h2 class="accordion-header" id="flush-headingTwo">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse"
                            data-bs-target="#flush-collapseTwo" aria-expanded="false"
                            aria-controls="flush-collapseTwo">
                        Filtrer par groupes
                    </button>
                </h2>
                <div id="flush-collapseTwo" class="accordion-collapse collapse"
                     aria-labelledby="flush-headingTwo"
                     data-bs-parent="#accordionGroupes">
                    <div class="accordion-body row">
                        <div>
                            <fieldset style="max-height: 200px; overflow-y: scroll;">
                                {% if this.selectedSemestreId == null %}
                                    {% for grp in this.groupes %}
                                        {% if grp.typeGroupe.type == 'TP' %}
                                            <small>
                                                {% if grp.apcParcours is not null %}
                                                    {{ grp.apcParcours.libelle }}
                                                    |
                                                    {% for semestre in grp.typeGroupe.semestre|filter(semestre => (semestre.annee.diplome.apcParcours == grp.apcParcours)) %}
                                                        {{ semestre.libelle }}
                                                    {% endfor %}
                                                {% else %}
                                                    S1
                                                {% endif %}
                                            </small>
                                            <div style="display: flex" class="form-check">
                                                <input type="checkbox" id="{{ grp.id }}"
                                                       name="{{ grp.id }}"
                                                       data-model="selectedGroupes[]"
                                                       data-action="live#action"
                                                       data-live-action-param="changeGroupes"
                                                       value="{{ grp.id }}"
                                                       class="form-check-input">
                                                <label for="{{ grp.id }}" style="margin-left: 10px"
                                                       class="form-check-label">
                                                    {{ grp.libelle }}
                                                </label><br>
                                            </div>
                                            <hr>
                                        {% endif %}
                                    {% endfor %}
                                {% else %}
                                    {% for grp in this.groupes %}
                                        {% if grp.typeGroupe.type == 'TP' %}
                                            <small>
                                                {% if grp.apcParcours is not null %}
                                                    {{ grp.apcParcours.code }}
                                                    |
                                                    {% for semestre in grp.typeGroupe.semestre|filter(semestre => (semestre.annee.diplome.apcParcours == grp.apcParcours)) %}
                                                        {{ semestre.libelle }}
                                                    {% endfor %}
                                                {% else %}
                                                    S1
                                                {% endif %}
                                            </small>
                                            <div style="display: flex" class="form-check">
                                                <input type="checkbox" id="{{ grp.id }}"
                                                       name="{{ grp.id }}"
                                                       data-model="selectedGroupes[]"
                                                       data-action="live#action"
                                                       data-live-action-param="changeGroupes"
                                                       value="{{ grp.id }}"
                                                       class="form-check-input">
                                                <label for="{{ grp.id }}" style="margin-left: 10px"
                                                       class="form-check-label">
                                                    {{ grp.libelle }}
                                                </label><br>
                                            </div>
                                            <hr>
                                        {% endif %}
                                    {% endfor %}
                                {% endif %}
                            </fieldset>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        {# Filtre étudiants #}
        <div class="accordion accordion-flush col-4 g-4 filter-drop" id="accordionEtudiants">
            <div class="accordion-item">
                <h2 class="accordion-header" id="flush-headingThree">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse"
                            data-bs-target="#flush-collapseThree" aria-expanded="false"
                            aria-controls="flush-collapseThree">
                        Filtrer par étudiants
                    </button>
                </h2>
                <div id="flush-collapseThree" class="accordion-collapse collapse"
                     aria-labelledby="flush-headingThree"
                     data-bs-parent="#accordionEtudiants">
                    <div class="accordion-body row">
                        <div>
                            <fieldset style="max-height: 200px; overflow-y: scroll;">
                                {% for etudiant in this.etudiants %}
                                    <small>
                                        {{ etudiant.semestre.libelle }}
                                    </small>
                                    <div style="display: flex" class="form-check">
                                        <input type="checkbox" id="{{ etudiant.id }}"
                                               name="{{ etudiant.id }}"
                                               data-model="selectedEtudiants[]"
                                               data-action="live#action"
                                               data-live-action-param="changeEtudiants"
                                               value="{{ etudiant.id }}"
                                               class="form-check-input">
                                        <label for="{{ etudiant.id }}" style="margin-left: 10px"
                                               class="form-check-label">{{ etudiant.prenom }} {{ etudiant.nom }}</label><br>
                                    </div>
                                    <hr>
                                {% endfor %}
                            </fieldset>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <hr>

    <div class="row">
        <div class="filtre-btn col-12">
            <button class="btn btn-secondary"
                    data-action="live#action"
                    data-live-action-param="changeEtat"
                    data-live-id-param="0"
                    {{ this.selectedEtat == 0 ? 'disabled' : '' }}
            >Toutes les traces</button>

            <button class="btn btn-secondary"
                    data-action="live#action"
                    data-live-action-param="changeEtat"
                    data-live-id-param="1"
                    {{ this.selectedEtat == 1 ? 'disabled' : '' }}
            >Traces évaluées</button>

            <button class="btn btn-secondary"
                    data-action="live#action"
                    data-live-action-param="changeEtat"
                    data-live-id-param="2"
                    {{ this.selectedEtat == 2 ? 'disabled' : '' }}
            >Traces non évaluées</button>
        </div>
    </div>

    <div class="row">
        {% for traceId in this.allTraces %}
            {{ component('TraceEvalCardComponent', {'id': traceId, 'key': traceId}) }}
        {% endfor %}
    </div>

    <div class="btn-pages">
        <button class="btn btn-primary"
                data-action="live#action"
                data-live-action-param="goToFirstPage"
                {{ this.currentPage == 1 or this.currentPage == 0 ? 'disabled' : '' }}
        >
            <i class="fa-solid fa-chevrons-left"></i>
        </button>

        <button class="btn btn-primary"
                data-action="live#action"
                data-live-action-param="goPreviousPage"
                {{ this.currentPage == 1 or this.currentPage == 0 ? 'disabled' : '' }}
        >
            <i class="fa-solid fa-chevron-left"></i>
        </button>

        <small>
            Page {{ this.currentPage }} / {{ this.getTotalPages }}
        </small>

        <button class="btn btn-primary"
                data-action="live#action"
                data-live-action-param="goNextPage"
                {{ this.currentPage == this.getTotalPages ? 'disabled' : '' }}
        >
            <i class="fa-solid fa-chevron-right"></i>
        </button>

        <button class="btn btn-primary"
                data-action="live#action"
                data-live-action-param="goToLastPage"
                {{ this.currentPage == this.getTotalPages ? 'disabled' : '' }}
        >
            <i class="fa-solid fa-chevrons-right"></i>
        </button>
    </div>
</div>
